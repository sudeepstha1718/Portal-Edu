rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - Deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate the document payload structure
    function isValidSubmission(data) {
      return data.keys().hasAll(['id', 'name', 'projectName', 'class', 'rollNo', 'screenshot', 'createdAt'])
        && data.keys().size() >= 7 && data.keys().size() <= 10
        // Verify key types and length bounds to guard against resource-poisoning attacks
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.projectName is string && data.projectName.size() > 0 && data.projectName.size() <= 200
        && data.class is string && data.class.size() > 0 && data.class.size() <= 100
        && data.rollNo is string && data.rollNo.size() > 0 && data.rollNo.size() <= 100
        && data.screenshot is string && data.screenshot.size() > 0 && data.screenshot.size() <= 1200000
        && data.createdAt is int
        && (!data.keys().hasAll(['projectFileName']) || (data.projectFileName is string && data.projectFileName.size() <= 500))
        && (!data.keys().hasAll(['projectFileContent']) || (data.projectFileContent is string && data.projectFileContent.size() <= 6000000))
        && (!data.keys().hasAll(['grade']) || (data.grade is string && data.grade.size() <= 100));
    }

    match /submissions/{submissionId} {
      // Public submissions creation with strict structural and content validation
      allow create, update: if isValidSubmission(request.resource.data);
      
      // Allow reading and displaying submissions so the teacher can access and download/print them
      allow read: if true;
      
      // Allow deletion to manage the feed/clean up entries
      allow delete: if true;
    }
  }
}
